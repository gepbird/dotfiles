--- a/terminal/terminal-widget.c
+++ b/terminal/terminal-widget.c
@@ -851,6 +851,14 @@
       return TRUE;
     }

+  /* Shift+Enter: send kitty keyboard protocol sequence so apps
+   * can distinguish it from plain Enter (VTE maps both to \r by default) */
+  if (event->keyval == GDK_KEY_Return && (event->state & GDK_SHIFT_MASK) != 0)
+    {
+      vte_terminal_feed_child (VTE_TERMINAL (widget), "\x1b[13;2u", 7);
+      return TRUE;
+    }
+
   return (*GTK_WIDGET_CLASS (terminal_widget_parent_class)->key_press_event) (widget, event);
 }
